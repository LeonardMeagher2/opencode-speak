{
  "name": "opencode-speak",
  "version": "0.1.0",
  "description": "Voice mode plugin for opencode -- speak to your AI assistant on Windows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "bun build src/index.ts --outfile .opencode/plugins/opencode-speak.js --target bun --external whisper-cpp-node",
    "dev:tui": "bun build src/tui.ts --outfile .opencode/plugins/opencode-speak-tui.js --target bun --external whisper-cpp-node",
    "dev:all": "bun run dev && bun run dev:tui",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "whisper-cpp-node": "^0.2.12"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "keywords": ["opencode", "plugin", "voice", "speech", "windows"],
  "publishConfig": {
    "access": "public"
  }
}
